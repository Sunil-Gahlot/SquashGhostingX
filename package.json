  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@testing-library/react-native": "^12.9.0",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.0",
    "@types/react-test-renderer": "^19.0.0",
    "babel-preset-expo": "~54.0.11",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.4",
