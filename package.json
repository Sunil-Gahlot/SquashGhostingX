    "@react-navigation/bottom-tabs": "^6.6.1",
    "@react-navigation/native": "^6.1.18",
    "expo": "~54.0.34",
    "expo-asset": "~12.0.13",
    "expo-audio": "~1.1.1",
    "expo-brightness": "~14.0.8",
    "expo-build-properties": "~1.0.10",
    "expo-crypto": "~15.0.9",
    "expo-font": "~14.0.12",
    "expo-haptics": "~15.0.8",
    "expo-image-picker": "~17.0.11",
    "expo-keep-awake": "~15.0.8",
    "expo-secure-store": "~15.0.8",
