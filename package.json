{
  "name": "squashghostingx",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "start:tunnel": "expo start --tunnel",
    "start-tunnel": "expo start --tunnel",
    "test": "jest",
    "test:timing": "jest --testPathPattern=timing",
